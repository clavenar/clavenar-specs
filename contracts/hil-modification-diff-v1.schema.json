{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clavenar.dev/contracts/hil-modification-diff-v1.schema.json",
  "title": "Clavenar HIL modification diff v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "replacements"],
  "properties": {
    "contract": {
      "const": "clavenar.hil.modification-diff/v1"
    },
    "replacements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "$ref": "#/$defs/argumentScalarReplacement"
      }
    }
  },
  "$defs": {
    "argumentScalarReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "value"],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[^~/\\u0000-\\u001f\\u007f]+$"
          }
        },
        "value": {
          "type": ["string", "number", "integer", "boolean", "null"]
        }
      }
    }
  }
}
