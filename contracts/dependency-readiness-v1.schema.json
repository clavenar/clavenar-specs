{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clavenar.com/contracts/dependency-readiness-v1.schema.json",
  "title": "Clavenar dependency-aware readiness inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contract",
    "response",
    "limits",
    "services"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "contract": {"const": "clavenar.dependency-readiness/v1"},
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readyStatus", "notReadyStatus", "checkValues", "sanitized"],
      "properties": {
        "readyStatus": {"const": "ready"},
        "notReadyStatus": {"const": "not_ready"},
        "checkValues": {
          "type": "array",
          "prefixItems": [
            {"const": "ok"},
            {"const": "fail"},
            {"const": "skipped"}
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "sanitized": {"const": true}
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probeTimeoutMillis",
        "responseMaxBytes",
        "startupFailureThreshold",
        "externalProviderProbe"
      ],
      "properties": {
        "probeTimeoutMillis": {"type": "integer", "minimum": 100, "maximum": 2000},
        "responseMaxBytes": {"type": "integer", "minimum": 256, "maximum": 4096},
        "startupFailureThreshold": {"type": "integer", "minimum": 3, "maximum": 60},
        "externalProviderProbe": {"const": "configuration-only"}
      }
    },
    "services": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {"$ref": "#/$defs/service"}
    }
  },
  "$defs": {
    "serviceId": {
      "enum": [
        "nats",
        "vault",
        "vault-custodian",
        "bootstrap",
        "upstream-stub",
        "identity",
        "brain",
        "policy-engine",
        "ledger",
        "hil",
        "deep-review",
        "proxy",
        "assurance",
        "console",
        "demo-mint",
        "simulator",
        "website"
      ]
    },
    "topology": {
      "enum": ["compose", "helm"]
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target"],
      "properties": {
        "type": {"enum": ["http", "command", "process", "completion"]},
        "target": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[ -~]+$"
        }
      }
    },
    "startupEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "topologies"],
      "properties": {
        "service": {"$ref": "#/$defs/serviceId"},
        "topologies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/topology"}
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topologies",
        "requiredWhenEnabled",
        "liveness",
        "readiness",
        "checks",
        "startupAfter",
        "failureMode",
        "sideEffectFree",
        "providerProbe"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/serviceId"},
        "topologies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/topology"}
        },
        "requiredWhenEnabled": {"const": true},
        "liveness": {"$ref": "#/$defs/probe"},
        "readiness": {"$ref": "#/$defs/probe"},
        "checks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          }
        },
        "startupAfter": {
          "type": "array",
          "maxItems": 12,
          "items": {"$ref": "#/$defs/startupEdge"}
        },
        "failureMode": {
          "enum": ["http-503", "command-nonzero", "completion-nonzero"]
        },
        "sideEffectFree": {"const": true},
        "providerProbe": {"enum": ["none", "configuration-only"]}
      }
    }
  }
}
