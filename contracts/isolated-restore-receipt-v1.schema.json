{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.clavenar.com/contracts/isolated-restore-receipt-v1.schema.json",
  "title": "Clavenar isolated restore receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contract",
    "restoreId",
    "release",
    "source",
    "chain",
    "isolation",
    "coverage",
    "stateResults",
    "validation",
    "timing",
    "doesNotAssert",
    "result"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "contract": {"const": "clavenar.isolated-restore-receipt/v1"},
    "restoreId": {
      "type": "string",
      "pattern": "^restore-[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "reference", "bomSha256", "exactImages"],
      "properties": {
        "version": {"$ref": "#/$defs/semver"},
        "reference": {"$ref": "#/$defs/digestReference"},
        "bomSha256": {"$ref": "#/$defs/sha256"},
        "exactImages": {"const": 11}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backupId",
        "reference",
        "objectDigest",
        "snapshotId",
        "inventorySha256",
        "planSha256",
        "recoveryPoint"
      ],
      "properties": {
        "backupId": {
          "type": "string",
          "pattern": "^backup-[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$"
        },
        "reference": {"$ref": "#/$defs/digestReference"},
        "objectDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "snapshotId": {"$ref": "#/$defs/sha256"},
        "inventorySha256": {"$ref": "#/$defs/sha256"},
        "planSha256": {"$ref": "#/$defs/sha256"},
        "recoveryPoint": {"type": "string", "format": "date-time"}
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objects",
        "oldestObject",
        "newestObject",
        "complete",
        "metadataVerified",
        "encryptedDeltasVerified",
        "repositoryCheck",
        "exactSnapshot",
        "plaintextImported"
      ],
      "properties": {
        "objects": {"type": "integer", "minimum": 1},
        "oldestObject": {"$ref": "#/$defs/digestReference"},
        "newestObject": {"$ref": "#/$defs/digestReference"},
        "complete": {"const": true},
        "metadataVerified": {"const": true},
        "encryptedDeltasVerified": {"const": true},
        "repositoryCheck": {"const": true},
        "exactSnapshot": {"const": true},
        "plaintextImported": {"const": false}
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectName",
        "productionProjectName",
        "freshNamespace",
        "freshVolumes",
        "productionContainersChanged",
        "productionVolumesMounted",
        "sharedNetworks",
        "hostPortsPublished",
        "productionResolvable"
      ],
      "properties": {
        "projectName": {
          "type": "string",
          "pattern": "^clavenar-restore-[a-z0-9-]+$"
        },
        "productionProjectName": {"const": "clavenar-prod"},
        "freshNamespace": {"const": true},
        "freshVolumes": {"const": true},
        "productionContainersChanged": {"const": 0},
        "productionVolumesMounted": {"const": 0},
        "sharedNetworks": {"const": 0},
        "hostPortsPublished": {"const": 0},
        "productionResolvable": {"const": false}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capturedStateIds",
        "externalCustodyStateIds",
        "reconstructibleStateIds",
        "signedSourceStateIds"
      ],
      "properties": {
        "capturedStateIds": {"$ref": "#/$defs/stateIds"},
        "externalCustodyStateIds": {"$ref": "#/$defs/stateIds"},
        "reconstructibleStateIds": {"$ref": "#/$defs/stateIds"},
        "signedSourceStateIds": {"$ref": "#/$defs/stateIds"}
      }
    },
    "stateResults": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": {"$ref": "#/$defs/stateResult"}
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sqlite", "jetstream", "vault", "identities", "stack", "ancillary"],
      "properties": {
        "sqlite": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "databases",
            "quickCheck",
            "policyMutationExact",
            "hilStateExact",
            "identityStateExact",
            "ledgerChain",
            "ledgerSignatures",
            "tsaHistory"
          ],
          "properties": {
            "databases": {"const": 5},
            "quickCheck": {"const": true},
            "policyMutationExact": {"const": true},
            "hilStateExact": {"const": true},
            "identityStateExact": {"const": true},
            "ledgerChain": {"const": true},
            "ledgerSignatures": {"const": true},
            "tsaHistory": {"const": true}
          }
        },
        "jetstream": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "streams",
            "consumers",
            "kvBuckets",
            "sequencesExact",
            "authorizationEnforced"
          ],
          "properties": {
            "streams": {"type": "integer", "minimum": 1},
            "consumers": {"type": "integer", "minimum": 1},
            "kvBuckets": {"type": "integer", "minimum": 1},
            "sequencesExact": {"const": true},
            "authorizationEnforced": {"const": true}
          }
        },
        "vault": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "storageVerified",
            "recoveryMaterialVerified",
            "transitHistoryExact",
            "applicationSecretsVerified",
            "attestationAuthorityVerified",
            "workloadPkiAuthorityVerified",
            "trustHistoryVerified"
          ],
          "properties": {
            "storageVerified": {"const": true},
            "recoveryMaterialVerified": {"const": true},
            "transitHistoryExact": {"const": true},
            "applicationSecretsVerified": {"const": true},
            "attestationAuthorityVerified": {"const": true},
            "workloadPkiAuthorityVerified": {"const": true},
            "trustHistoryVerified": {"const": true}
          }
        },
        "identities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "privateKeysCopied",
            "workloadIdentitiesReissued",
            "simulatorIdentitiesReissued",
            "signedOneUseRecovery"
          ],
          "properties": {
            "privateKeysCopied": {"const": false},
            "workloadIdentitiesReissued": {"type": "integer", "minimum": 1},
            "simulatorIdentitiesReissued": {"type": "integer", "minimum": 1},
            "signedOneUseRecovery": {"const": true}
          }
        },
        "stack": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "servicesReady",
            "exactRelease",
            "representativeGovernedTransaction"
          ],
          "properties": {
            "servicesReady": {"type": "integer", "minimum": 11},
            "exactRelease": {"const": true},
            "representativeGovernedTransaction": {"const": true}
          }
        },
        "ancillary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operatorTrustVerified",
            "releaseConfigurationVerified",
            "caddyStateVerified",
            "observabilityStateVerified"
          ],
          "properties": {
            "operatorTrustVerified": {"const": true},
            "releaseConfigurationVerified": {"const": true},
            "caddyStateVerified": {"const": true},
            "observabilityStateVerified": {"const": true}
          }
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startedAt",
        "readyAt",
        "validatedAt",
        "sourceAgeSeconds",
        "restoreDurationSeconds",
        "lossWindowSeconds"
      ],
      "properties": {
        "startedAt": {"type": "string", "format": "date-time"},
        "readyAt": {"type": "string", "format": "date-time"},
        "validatedAt": {"type": "string", "format": "date-time"},
        "sourceAgeSeconds": {"type": "integer", "minimum": 0},
        "restoreDurationSeconds": {"type": "integer", "minimum": 0},
        "lossWindowSeconds": {"type": "integer", "minimum": 0}
      }
    },
    "doesNotAssert": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": ["disaster-recovery", "upgrade-safety"]
      }
    },
    "result": {"const": "pass"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "digestReference": {
      "type": "string",
      "pattern": "^.+@sha256:[a-f0-9]{64}$"
    },
    "stateIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "stateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stateId",
        "disposition",
        "objectiveProfile",
        "rpoSeconds",
        "rtoSeconds",
        "lossSeconds",
        "restoreSeconds",
        "withinRpo",
        "withinRto",
        "contentSha256",
        "integrityVerified",
        "functionalVerified"
      ],
      "properties": {
        "stateId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "disposition": {
          "enum": ["restored", "external-custody", "reconstructed", "signed-source"]
        },
        "objectiveProfile": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "rpoSeconds": {"type": "integer", "minimum": 0, "maximum": 86400},
        "rtoSeconds": {"type": "integer", "minimum": 1, "maximum": 604800},
        "lossSeconds": {"type": "integer", "minimum": 0},
        "restoreSeconds": {"type": "integer", "minimum": 0},
        "withinRpo": {"const": true},
        "withinRto": {"const": true},
        "contentSha256": {"$ref": "#/$defs/sha256"},
        "integrityVerified": {"const": true},
        "functionalVerified": {"const": true}
      }
    }
  }
}
