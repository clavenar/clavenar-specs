{
  "schemaVersion": 1,
  "contract": "clavenar.state-recovery-inventory/v1",
  "approval": {
    "status": "approved",
    "scope": "inventory-and-scheduled-backup",
    "doesNotAssert": [
      "isolated-restore",
      "disaster-recovery",
      "upgrade-safety"
    ]
  },
  "topologies": [
    {
      "id": "compose-single-host",
      "writerMode": "sqlite-single-writer",
      "brokerBoundary": "single-node-retained",
      "vaultBoundary": "single-node-retained",
      "wholeStackHaClaim": false
    },
    {
      "id": "helm-single-writer",
      "writerMode": "sqlite-single-writer-recreate",
      "brokerBoundary": "operator-supplied-or-bundled",
      "vaultBoundary": "operator-supplied-or-bundled",
      "wholeStackHaClaim": false
    }
  ],
  "profiles": {
    "objectives": [
      {
        "id": "immutable-release",
        "rpoSeconds": 0,
        "rtoSeconds": 1800,
        "lossResponse": "refuse unsigned or digest-mismatched redeployment"
      },
      {
        "id": "zero-loss-critical",
        "rpoSeconds": 0,
        "rtoSeconds": 3600,
        "lossResponse": "hold dependent authority closed until exact recovery"
      },
      {
        "id": "critical-five-minute",
        "rpoSeconds": 300,
        "rtoSeconds": 3600,
        "lossResponse": "hold writes and dependent readiness closed"
      },
      {
        "id": "critical-hour",
        "rpoSeconds": 3600,
        "rtoSeconds": 14400,
        "lossResponse": "keep affected optional or administrative surface unavailable"
      },
      {
        "id": "reconstructible-hour",
        "rpoSeconds": 3600,
        "rtoSeconds": 7200,
        "lossResponse": "open explicit one-use recovery and reissue without restoring private keys"
      },
      {
        "id": "observability-day",
        "rpoSeconds": 86400,
        "rtoSeconds": 86400,
        "lossResponse": "restore alerting first and record the bounded telemetry gap"
      }
    ],
    "consistency": [
      {
        "id": "signed-redeployment",
        "mechanism": "signed-redeployment",
        "boundary": "one verified immutable release and configuration generation",
        "quiesce": "none; verify digest and signature before use"
      },
      {
        "id": "atomic-restricted-copy",
        "mechanism": "atomic-restricted-copy",
        "boundary": "one complete owner-restricted file generation",
        "quiesce": "stop the writer or use its atomic projection boundary"
      },
      {
        "id": "identity-reissue",
        "mechanism": "identity-reissue",
        "boundary": "one exact current credential generation",
        "quiesce": "stop the workload before opening signed one-use recovery"
      },
      {
        "id": "sqlite-online-backup",
        "mechanism": "sqlite-online-backup",
        "boundary": "one SQLite backup API or validated transactionally consistent snapshot",
        "quiesce": "online backup preferred; otherwise stop the sole writer"
      },
      {
        "id": "sqlite-or-postgres-snapshot",
        "mechanism": "sqlite-or-postgres-snapshot",
        "boundary": "one validated SQLite backup or native PostgreSQL consistent snapshot",
        "quiesce": "coordinate the selected backend and reject mixed checkpoints"
      },
      {
        "id": "jetstream-snapshot",
        "mechanism": "jetstream-snapshot",
        "boundary": "one broker snapshot containing stream, consumer, KV, and replay state",
        "quiesce": "pause publishers or bind the snapshot to an acknowledged sequence barrier"
      },
      {
        "id": "vault-snapshot",
        "mechanism": "vault-snapshot",
        "boundary": "one sealed Vault storage snapshot plus separately held recovery material",
        "quiesce": "use the supported storage snapshot barrier"
      },
      {
        "id": "caddy-data-snapshot",
        "mechanism": "caddy-data-snapshot",
        "boundary": "one Caddy data and configuration generation",
        "quiesce": "stop Caddy or use an atomic filesystem snapshot"
      },
      {
        "id": "observability-snapshot",
        "mechanism": "observability-snapshot",
        "boundary": "one aligned metrics, dashboard, alert, and routing generation",
        "quiesce": "snapshot retained stores after configuration is committed"
      }
    ],
    "lifecycle": [
      {
        "id": "release-history",
        "minimumRetentionSeconds": 220752000,
        "maximumRetentionSeconds": 315360000,
        "deletionTrigger": "superseded release is outside the ten-year verification window",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "contains no tenant payload; preserve signed provenance"
      },
      {
        "id": "forensic-evidence",
        "minimumRetentionSeconds": 15811200,
        "maximumRetentionSeconds": 220752000,
        "deletionTrigger": "approved evidence retention expires and no hold applies",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "retain immutable tombstone and commitments while removing separately purgeable payload material"
      },
      {
        "id": "authority-history",
        "minimumRetentionSeconds": 15811200,
        "maximumRetentionSeconds": 220752000,
        "deletionTrigger": "authority is retired and its evidence-verification window expires",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "decommission tenant authority and retain only required signed lifecycle evidence"
      },
      {
        "id": "hil-sensitive",
        "minimumRetentionSeconds": 0,
        "maximumRetentionSeconds": 2592000,
        "deletionTrigger": "decision reaches terminal state and the thirty-day review window expires",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "erase raw and modified payloads; retain only minimized held audit metadata when legally required"
      },
      {
        "id": "secret-generation",
        "minimumRetentionSeconds": 0,
        "maximumRetentionSeconds": 2592000,
        "deletionTrigger": "replacement is active and the bounded overlap or rollback window expires",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "destroy tenant-scoped secret generations after dependent evidence no longer requires them"
      },
      {
        "id": "key-history",
        "minimumRetentionSeconds": 15811200,
        "maximumRetentionSeconds": 220752000,
        "deletionTrigger": "no retained evidence can reference the retired key generation",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "destroy tenant private material while retaining public verification lineage required by held evidence"
      },
      {
        "id": "current-credential",
        "minimumRetentionSeconds": 0,
        "maximumRetentionSeconds": 4500,
        "deletionTrigger": "credential expires or replacement overlap completes",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "destroy private key immediately; retained public lifecycle evidence follows authority-history"
      },
      {
        "id": "acme-state",
        "minimumRetentionSeconds": 0,
        "maximumRetentionSeconds": 31536000,
        "deletionTrigger": "account and certificates are superseded and no rollback requires them",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "not tenant payload; remove retired account material after certificate replacement"
      },
      {
        "id": "observability-window",
        "minimumRetentionSeconds": 2592000,
        "maximumRetentionSeconds": 7776000,
        "deletionTrigger": "the ninety-day operational investigation window expires",
        "legalHold": "extend-until-authorized-release",
        "tenantErasure": "delete tenant-bearing labels or exemplars unless a documented hold applies"
      }
    ],
    "encryption": [
      {
        "id": "signed-public",
        "inTransit": "TLS plus signature and digest verification",
        "atRestRequired": true,
        "atRestControl": "encrypted platform storage with signed immutable provenance",
        "keyCustodian": "Release",
        "separateRecoveryCustody": false
      },
      {
        "id": "restricted-state",
        "inTransit": "mTLS or authenticated TLS",
        "atRestRequired": true,
        "atRestControl": "volume and offsite-object encryption with managed keys",
        "keyCustodian": "Platform Security",
        "separateRecoveryCustody": false
      },
      {
        "id": "security-key-material",
        "inTransit": "mTLS or approved offline transfer",
        "atRestRequired": true,
        "atRestControl": "envelope or hardware-backed encryption outside application storage",
        "keyCustodian": "Security",
        "separateRecoveryCustody": true
      },
      {
        "id": "public-trust",
        "inTransit": "TLS with digest verification",
        "atRestRequired": true,
        "atRestControl": "encrypted platform storage with integrity metadata",
        "keyCustodian": "Security",
        "separateRecoveryCustody": false
      },
      {
        "id": "observability-state",
        "inTransit": "authenticated TLS",
        "atRestRequired": true,
        "atRestControl": "encrypted metrics and configuration storage",
        "keyCustodian": "SRE",
        "separateRecoveryCustody": false
      }
    ]
  },
  "states": [
    {
