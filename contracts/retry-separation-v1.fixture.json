  "invariants": {
    "onlyExclusiveDecisionRequestsMayRetryAutomatically": true,
    "decisionRetriesRetainOriginalCanonicalIdempotencyId": true,
    "executorFailuresNeverEnterTransportRetryLoop": true,
    "upstreamFailuresNeverEnterTransportRetryLoop": true,
    "pollingNeverResubmitsOriginalRequest": true,
